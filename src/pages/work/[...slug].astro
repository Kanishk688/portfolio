---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

// getStaticPaths = Astro ko batao "kaun-kaun se pages banane hain".
// Har project ke liye ek page. slug = us project ka address (file ka naam).
export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((p) => ({
    params: { slug: p.id },   // URL ka hissa, e.g. /work/jaipuria-science-textbook
    props: { project: p },    // us page ko poora project data de do
  }));
}

// Upar se aaya hua project data.
const { project } = Astro.props;
// render() = markdown ke neeche wale text ko HTML me badalta hai.
const { Content } = await render(project);

// gallery ke har item ko ek jaisa {src, chapter, caption} bana lete hain
// (kabhi wo sirf string hota hai, kabhi object).
const items = project.data.gallery.map((g) =>
  typeof g === 'string' ? { src: g, chapter: undefined, caption: undefined } : g
);

// chapter ke hisaab se group karo, aur order wahi rakho jaise likha hai.
const groups: { chapter: string; images: typeof items }[] = [];
for (const it of items) {
  const key = it.chapter ?? '';
  let g = groups.find((x) => x.chapter === key);
  if (!g) { g = { chapter: key, images: [] }; groups.push(g); }
  g.images.push(it);
}
---

<Layout title={`${project.data.title} — Kanishk Verma`}>
  <main class="max-w-5xl mx-auto px-6 py-16">
    <!-- Wapas jaane ka link -->
    <a href="/work" class="text-sm text-neutral-400 hover:text-white transition">← Back to Work</a>

    <!-- Title + summary -->
    <h1 class="text-4xl md:text-5xl font-black mt-6">{project.data.title}</h1>
    <p class="text-lg text-neutral-300 mt-3 max-w-2xl">{project.data.summary}</p>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2 mt-4">
      {project.data.tags.map((t) => (
        <span class="text-xs rounded-full bg-neutral-800 text-neutral-300 px-2.5 py-1">{t}</span>
      ))}
    </div>

    <!-- Markdown body (file ke neeche wala likha hua text) -->
    <div class="prose prose-invert mt-8 max-w-2xl text-neutral-300">
      <Content />
    </div>

    <!-- GALLERY = chapter ke hisaab se. Image pe click = zoom (lightbox) -->
    {groups.map((group) => (
      <section class="mt-14">
        {group.chapter && (
          <h2 class="text-xl md:text-2xl font-bold border-l-4 border-teal-400 pl-3 mb-6">
            {group.chapter}
          </h2>
        )}
        <div class="grid gap-6 sm:grid-cols-2">
          {group.images.map((img) => (
            <figure class="group">
              <img
                src={img.src}
                alt={img.caption ?? project.data.title}
                class="lightbox-img w-full rounded-xl border border-neutral-800 cursor-zoom-in hover:opacity-90 transition"
                loading="lazy"
              />
              {img.caption && (
                <figcaption class="text-sm text-neutral-400 mt-2 leading-snug">{img.caption}</figcaption>
              )}
            </figure>
          ))}
        </div>
      </section>
    ))}
  </main>

  <!-- LIGHTBOX = poori screen wala zoom. Kisi bhi gallery image pe click karo to khulta hai. -->
  <div id="lightbox" class="fixed inset-0 z-[100] hidden items-center justify-center bg-black/90 p-4 cursor-zoom-out">
    <img id="lightbox-img" src="" alt="" class="max-h-[90vh] max-w-[90vw] rounded-lg" />
  </div>

  <script is:inline>
    const box = document.getElementById('lightbox');
    const boxImg = document.getElementById('lightbox-img');
    // har gallery image pe click lagao
    document.querySelectorAll('.lightbox-img').forEach((el) => {
      el.addEventListener('click', () => {
        boxImg.src = el.src;
        box.classList.remove('hidden');
        box.classList.add('flex');
      });
    });
    // overlay pe click ya Escape dabao to band
    function closeBox() { box.classList.add('hidden'); box.classList.remove('flex'); boxImg.src = ''; }
    box.addEventListener('click', closeBox);
    document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeBox(); });
  </script>
</Layout>
