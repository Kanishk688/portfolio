---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

// getCollection = "projects" folder ki saari files uthao.
const projects = await getCollection('projects');
// naye kaam upar dikhein isliye date se ulta sort karte hain.
projects.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Layout title="Work — Kanishk Verma">
  <main class="max-w-6xl mx-auto px-6 py-16">
    <h1 class="text-5xl font-black mb-2">Work</h1>
    <p class="text-neutral-400 mb-10">Selected illustration projects.</p>

    <!-- Har project ka card. map() = list me har item ke liye ek card banao. -->
    <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {projects.map((p) => (
        <li class="group rounded-2xl overflow-hidden border border-neutral-800 bg-neutral-900 hover:border-neutral-600 transition">
          <a href={`/work/${p.id}`} class="block">
          <img
            src={p.data.cover}
            alt={p.data.title}
            class="aspect-[4/3] w-full object-cover group-hover:scale-105 transition duration-300"
          />
          <div class="p-5">
            <h2 class="font-bold text-lg leading-snug">{p.data.title}</h2>
            <p class="text-sm text-neutral-400 mt-2 line-clamp-2">{p.data.summary}</p>
            <div class="flex flex-wrap gap-2 mt-3">
              {p.data.tags.map((t) => (
                <span class="text-xs rounded-full bg-neutral-800 text-neutral-300 px-2.5 py-1">{t}</span>
              ))}
            </div>
          </div>
          </a>
        </li>
      ))}
    </ul>
  </main>
</Layout>
